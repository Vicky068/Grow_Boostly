<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force the final production host/protocol while keeping localhost usable.
    RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
    RewriteCond %{HTTP_HOST} !^www\.growboostly\.com$ [NC,OR]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://www.growboostly.com%{REQUEST_URI} [R=301,L]

    # Legacy .html/.htm URLs. This project has no .html files, so redirect to clean URLs.
    RewriteRule ^index\.html?$ / [R=301,L]
    RewriteRule ^service-details\.html?$ /services [R=301,L]
    RewriteRule ^cart\.html?$ /packages [R=301,L]
    RewriteRule ^(.+)\.html?$ /$1 [R=301,L,NE]

    # Other legacy/stale URLs seen by Google Search Console.
    RewriteRule ^sales-funnel-development-services/?$ /services/sales-funnel-development [R=301,L]
    RewriteRule ^performance-marketing/google-ads(?:\.php)?/?$ /services/google-ads [R=301,L]
    RewriteRule ^services/performance-marketing/google-ads/?$ /services/google-ads [R=301,L]
    RewriteRule ^services/contact(?:\.php)?/?$ /contact [R=301,L]

    # Normalize non-directory trailing slashes to the final canonical URL.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [R=301,L]

    # Redirect /page.php -> /page (before serving existing .php files)
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteCond %{REQUEST_URI} !^/assets/ [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Only skip real files — not directories (avoids 403 on /industries/ and /pricing/)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Hub pages: root .php file shares name with a subfolder (no index in subfolder)
    RewriteRule ^industries/?$ industries.php [L]
    RewriteRule ^pricing/?$ /packages [R=301,L]
    RewriteRule ^pricing/(.+)-pricing/?$ /packages/$1-packages [R=301,L]
    RewriteRule ^packages/?$ packages.php [L]
    RewriteRule ^services/?$ services/index.php [L]

    # Redirect /folder/index.php -> /folder
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteCond %{THE_REQUEST} \s/+([^?\s]*/?)index\.php[\s?] [NC]
    RewriteRule ^ %1 [R=301,L,NE]

    # /services/b2b-lead-generation -> services/b2b-lead-generation.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.+?)/?$ $1.php [L,QSA]

    # /some-folder -> some-folder/index.php (when index exists)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}/index.php -f
    RewriteRule ^(.+?)/?$ $1/index.php [L,QSA]
</IfModule>
